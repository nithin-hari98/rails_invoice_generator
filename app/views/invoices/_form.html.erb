<%= form_with(model: invoice) do |form| %>
  <% if invoice.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(invoice.errors.count, "error") %> prohibited this invoice from being saved:</h2>
      <ul>
        <% invoice.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :date %>
    <%= form.date_field :date %>
  </div>

  <div class="field">
    <%= form.label :due_date %>
    <%= form.date_field :due_date %>
  </div>

  <div class="field">
    <%= form.label :client_name %>
    <%= form.text_field :client_name %>
  </div>

  <div class="field">
    <%= form.label :client_email %>
    <%= form.email_field :client_email %>
  </div>

  <div class="field">
    <%= form.label :status %>
    <%= form.select :status, ['draft', 'sent', 'paid', 'cancelled'] %>
  </div>

  <h3>Line Items</h3>
  <div id="line-items">
    <%= form.fields_for :line_items do |line_item| %>
      <%= render 'line_item_fields', f: line_item %>
    <% end %>
  </div>

  <div class="links">
    <%= link_to_add_association 'Add Line Item', form, :line_items, 
        partial: 'line_item_fields',
        class: 'add-line-item-button',
        data: { association_insertion_node: '#line-items' } %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>